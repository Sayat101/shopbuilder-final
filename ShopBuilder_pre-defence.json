{
  "info": {
    "name": "ShopBuilder Final API",
    "_postman_id": "shopbuilder-final",
    "description": "Full API collection for ShopBuilder platform.\n\nCorrect execution order:\n1. Register Super Admin → Login Super Admin\n2. Register Merchant (subdomain auto-creates tenant) → Check email → Verify email → Login Merchant\n3. Register Customer → Verify email → Login Customer\n4. Create Product → Add to Cart → Place Order → Pay\n\naccessToken: short-lived (15 min), sent as Bearer token\nrefreshToken: long-lived (7 days), used to refresh access",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "superAdminToken",
      "value": ""
    },
    {
      "key": "merchantToken",
      "value": ""
    },
    {
      "key": "customerToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "tenantId",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "variantId",
      "value": ""
    },
    {
      "key": "cartId",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "verifyToken",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1 · Auth",
      "description": "JWT authentication with email verification. Three roles: SUPER_ADMIN, MERCHANT, CUSTOMER.\n\nMERCHANT: register with subdomain → tenant auto-created → verify email → login\nCUSTOMER: register → verify email → login\nSUPER_ADMIN: register → verify email → login",
      "item": [
        {
          "name": "Register Super Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopbuilder.kz\",\n  \"password\": \"Password123!\",\n  \"role\": \"SUPER_ADMIN\"\n}"
            },
            "description": "Register SUPER_ADMIN. No tenantId or subdomain needed — platform-level account. After registration check email for verification link."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "console.log('Register response:', JSON.stringify(res));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify Email (Super Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token={{verifyToken}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-email"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "{{verifyToken}}"
                }
              ]
            },
            "description": "Paste the token from the verification email into the verifyToken variable, then run this request. User cannot login until verified."
          }
        },
        {
          "name": "Login Super Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shopbuilder.kz\",\n  \"password\": \"Password123!\"\n}"
            },
            "description": "Login as SUPER_ADMIN. Saves superAdminToken and refreshToken automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('superAdminToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  console.log('superAdminToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register Merchant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@shopbuilder.kz\",\n  \"password\": \"Password123!\",\n  \"role\": \"MERCHANT\",\n  \"subdomain\": \"aigerim-bags\"\n}"
            },
            "description": "Register MERCHANT with subdomain. The system automatically creates a Tenant (store) for this merchant. tenantId is returned in the response and saved automatically. Check email for verification link."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.user && res.user.tenantId) {",
                  "  pm.collectionVariables.set('tenantId', res.user.tenantId);",
                  "  console.log('tenantId saved:', res.user.tenantId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify Email (Merchant)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token={{verifyToken}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-email"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "{{verifyToken}}"
                }
              ]
            },
            "description": "Paste the token from the merchant verification email into verifyToken variable."
          }
        },
        {
          "name": "Login Merchant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@shopbuilder.kz\",\n  \"password\": \"Password123!\"\n}"
            },
            "description": "Login as MERCHANT. Saves merchantToken automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('merchantToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  console.log('merchantToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@shopbuilder.kz\",\n  \"password\": \"Password123!\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "description": "Register CUSTOMER. No tenantId or subdomain needed. Check email for verification link."
          }
        },
        {
          "name": "Verify Email (Customer)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token={{verifyToken}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "verify-email"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "{{verifyToken}}"
                }
              ]
            },
            "description": "Paste the token from the customer verification email into verifyToken variable."
          }
        },
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@shopbuilder.kz\",\n  \"password\": \"Password123!\"\n}"
            },
            "description": "Login as CUSTOMER. Saves customerToken automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('customerToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  console.log('customerToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me",
            "description": "Returns the currently authenticated user info from JWT."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Get a new accessToken using refreshToken. Old refreshToken is rotated (invalidated)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('merchantToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@shopbuilder.kz\"\n}"
            },
            "description": "Request password reset email. Always returns success to prevent email enumeration attacks."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "description": "Reset password using token from email. Paste token from email into resetToken variable."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "description": "Revokes the refresh token in Redis. User must login again to get new tokens."
          }
        },
        {
          "name": "RBAC Test - Unauthorized (401)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Should fail - no token\"\n}"
            },
            "description": "Demonstrates RBAC: creating a product without a token returns 401 Unauthorized."
          }
        }
      ]
    },
    {
      "name": "2 · Tenants (SUPER_ADMIN)",
      "description": "Tenant management. SUPER_ADMIN can manually create and view all tenants.\nMerchants get their tenant auto-created during registration.",
      "item": [
        {
          "name": "Create Tenant (manual - SUPER_ADMIN only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": "{{baseUrl}}/tenants",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subdomain\": \"nukus-top\",\n  \"plan\": \"PRO\"\n}"
            },
            "description": "SUPER_ADMIN can manually create a tenant on behalf of someone. Merchants create their own tenant automatically during registration."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.tenant && res.tenant.id) {",
                  "  pm.collectionVariables.set('tenantId', res.tenant.id);",
                  "  console.log('tenantId saved:', res.tenant.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List All Tenants",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tenants?limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tenants"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "List all tenants with cursor-based pagination."
          }
        },
        {
          "name": "Get Tenant by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{superAdminToken}}"
              }
            ],
            "url": "{{baseUrl}}/tenants/{{tenantId}}",
            "description": "Get a specific tenant by ID."
          }
        }
      ]
    },
    {
      "name": "3 · Products (MERCHANT)",
      "description": "Product management with automatic variant matrix generation.\ntenantId is taken from the merchant's JWT token automatically.",
      "item": [
        {
          "name": "Create Product with Variants",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": "{{baseUrl}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sweater\",\n  \"description\": \"Warm winter sweater\",\n  \"price\": 15000,\n  \"options\": {\n    \"colors\": [\n      \"Red\",\n      \"Blue\"\n    ],\n    \"sizes\": [\n      \"S\",\n      \"M\",\n      \"L\"\n    ]\n  }\n}"
            },
            "description": "Creates product with 6 auto-generated SKUs (Red-S, Red-M, Red-L, Blue-S, Blue-M, Blue-L). tenantId is taken from JWT token automatically — no need to pass it."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.product && res.product.id) {",
                  "  pm.collectionVariables.set('productId', res.product.id);",
                  "  if (res.product.variants && res.product.variants.length > 0) {",
                  "    pm.collectionVariables.set('variantId', res.product.variants[0].id);",
                  "  }",
                  "  console.log('productId saved:', res.product.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products?limit=20&tenantId={{tenantId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "tenantId",
                  "value": "{{tenantId}}"
                }
              ]
            },
            "description": "List all products with cursor-based pagination."
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": "{{baseUrl}}/products/{{productId}}",
            "description": "Get product with all variants and inventory levels."
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": "{{baseUrl}}/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 17000,\n  \"description\": \"Updated: Premium warm winter sweater\"\n}"
            },
            "description": "Update product price or description."
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": "{{baseUrl}}/products/{{productId}}",
            "description": "Delete a product (MERCHANT only)."
          }
        }
      ]
    },
    {
      "name": "4 · Cart (CUSTOMER)",
      "description": "Shopping cart management for authenticated customers.",
      "item": [
        {
          "name": "Get My Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/cart",
            "description": "Get the current customer's cart with all items."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.cart && res.cart.id) {",
                  "  pm.collectionVariables.set('cartId', res.cart.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/cart/items",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variantId\": \"{{variantId}}\",\n  \"quantity\": 2\n}"
            },
            "description": "Add a product variant to cart. Creates cart if it doesn't exist."
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/cart/items/{{variantId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            },
            "description": "Update quantity of a specific cart item."
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/cart/items/{{variantId}}",
            "description": "Remove a specific item from the cart."
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/cart",
            "description": "Remove all items from the cart."
          }
        }
      ]
    },
    {
      "name": "5 · Orders (CUSTOMER + MERCHANT)",
      "description": "Order management. Customers place orders from their cart. Merchants manage order status.",
      "item": [
        {
          "name": "Place Order (from cart)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"shippingAddress\": {\n    \"name\": \"Aigerim Bekova\",\n    \"street\": \"Abay Ave 10\",\n    \"city\": \"Almaty\",\n    \"country\": \"KZ\",\n    \"zip\": \"050000\"\n  }\n}"
            },
            "description": "Place order from active cart. Reserves inventory, converts cart, sends order confirmation email. idempotencyKey is auto-generated server-side."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('orderId', res.id);",
                  "  console.log('orderId saved:', res.id);",
                  "} else if (res.order && res.order.id) {",
                  "  pm.collectionVariables.set('orderId', res.order.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get My Orders (Customer)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders?limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "List all orders for the authenticated customer."
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "description": "Get a specific order. Customers can only see their own orders."
          }
        },
        {
          "name": "List All Tenant Orders (Merchant)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{merchantToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/all?tenantId={{tenantId}}&status=PENDING",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "all"
              ],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenantId}}"
                },
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            },
            "description": "Merchant view: list all orders for their store. Filter by status: PENDING, PAID, FULFILLED, REFUNDED, CANCELLED."
          }
        },
        {
          "name": "Update Order Status (Merchant)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
